rm -rf /tmp/sp /project/docs/{Makefile,.sphinx}

git clone --depth 1 https://github.com/canonical/sphinx-docs-starter-pack /tmp/sp/
cp -ar /tmp/sp/docs/{Makefile,.sphinx} /project/docs/
sed -i 's/en_GB/en_US/g' /project/docs/.sphinx/spellingcheck.yaml
cd /project/docs/ && make install

rm -rf /tmp/sp/
